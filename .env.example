# JWT Secrets — thay bằng chuỗi ngẫu nhiên >= 32 ký tự, KHÁC nhau
ACCESS_TOKEN_KEY=your_access_token_secret_key_change_this!!
REFRESH_TOKEN_KEY=your_refresh_token_secret_key_change_this!

# Tuỳ chọn — ghi đè thời hạn token (mặc định: 15m / 168h)
# ACCESS_TOKEN_EXPIRY=15m
# REFRESH_TOKEN_EXPIRY=168h
