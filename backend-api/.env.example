# =============================================
# Fish Game Backend API - Environment Variables
# =============================================

# Server Configuration
SERVER_PORT=8080
APP_ENV=development

# SQL Server - Windows Authentication (Trusted Connection)
# DB_USER và DB_PASSWORD để trống = dùng Windows Auth (giống Trusted_Connection=yes trong FastAPI)
DB_HOST=GIGABYTE
DB_PORT=1433
DB_USER=
DB_PASSWORD=
DB_NAME=FishGameDB
DB_ENCRYPT=true
DB_TRUST_SERVER_CERT=true

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY_HOURS=24

# CORS Settings
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
