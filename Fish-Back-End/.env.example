# Server
SERVER_PORT=8080

# PostgreSQL
DATABASE_URL=postgres://postgres:your_password_here@localhost:5432/fish_game?sslmode=disable

# JWT — phải dài ít nhất 32 ký tự, đổi trước khi lên production
TOKEN_SYMMETRIC_KEY=your_32_characters_long_secret_key_here

# CORS — phân tách bằng dấu phẩy
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
