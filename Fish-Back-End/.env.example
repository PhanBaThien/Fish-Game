# ===================================================
# Fish Game Backend API - Environment Variables (Example)
# Coppy file này thành .env và điền thông tin thực tế của bạn
# ===================================================

# Server Configuration
SERVER_PORT=8080
APP_ENV=development # development | production

# SQL Server Configuration (Nếu dùng MSSQL)
# Để trống DB_USER và DB_PASSWORD nếu dùng Windows Authentication
DB_HOST=localhost
DB_PORT=1433
DB_USER=
DB_PASSWORD=
DB_NAME=FishGameDB
DB_ENCRYPT=true
DB_TRUST_SERVER_CERT=true

# PostgreSQL Connection String
# Định dạng: postgres://[USER]:[PASSWORD]@[HOST]:[PORT]/[DB_NAME]?sslmode=disable
DATABASE_URL=postgres://postgres:your_password_here@localhost:5432/fish_game?sslmode=disable

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Authentication
# CẢNH BÁO: Phải đổi JWT_SECRET ở môi trường production và dài ít nhất 32 ký tự
JWT_SECRET=your_32_characters_long_secret_key_here
JWT_EXPIRY_HOURS=24

# CORS Settings (Phân tách bằng dấu phẩy)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173