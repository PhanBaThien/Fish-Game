# Server
SERVER_PORT=8080

# PostgreSQL
DATABASE_URL=postgres://postgres:your_password@localhost:5432/fish_game?sslmode=disable

# Access Token — dùng ký JWT, phải >= 32 ký tự
ACCESS_TOKEN_KEY=your_access_token_secret_key_here!!
# Thời hạn: 15m | 1h | 24h (Go duration string)
ACCESS_TOKEN_EXPIRY=15m

# Refresh Token — secret riêng, phải >= 32 ký tự, khác ACCESS_TOKEN_KEY
REFRESH_TOKEN_KEY=your_refresh_token_secret_key_here!
# Thời hạn: 168h = 7 ngày
REFRESH_TOKEN_EXPIRY=168h

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
